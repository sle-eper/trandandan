# ---------------------------
# Stage 1: Optional - Install deps if needed
# ---------------------------
FROM node:20 AS build
WORKDIR /app

# Copy only if you actually have package.json (optional for tailwind setup)
COPY package*.json ./ 
RUN [ -f package.json ] && npm install || echo "No Node dependencies"

# Copy project files
COPY . .

# ---------------------------
# Stage 2: Serve static files with Nginx
# ---------------------------
FROM nginx:alpine

# Remove default nginx config and page
RUN rm -rf /usr/share/nginx/html/* /etc/nginx/conf.d/default.conf

# Copy your SPA files (HTML, CSS, JS, images)
COPY . /usr/share/nginx/html

# Copy your custom nginx config
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
